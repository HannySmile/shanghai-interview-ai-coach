page {
  background: #f5f6f2;
  color: #17201a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
textarea,
input,
picker {
  box-sizing: border-box;
}

button {
  border-radius: 12rpx;
  font-weight: 700;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #dfe4dc;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #667069;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.35;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2ed;
  color: #667069;
  font-size: 23rpx;
  font-weight: 700;
}

.tag.blue {
  background: #eaf3ff;
  color: #1d5fa7;
}

.primary {
  color: #ffffff;
  background: #0f766e;
}

.secondary {
  color: #0b5f59;
  background: #d9f2ee;
}

.danger {
  color: #ffffff;
  background: #d88d89;
}

.ghost {
  color: #667069;
  background: #eef2ed;
}
