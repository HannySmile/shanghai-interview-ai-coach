.filters {
  display: grid;
  gap: 14rpx;
  margin-top: 24rpx;
}

input,
.picker {
  min-height: 74rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe4dc;
  border-radius: 12rpx;
  background: #fbfcfa;
  line-height: 74rpx;
}

.count {
  margin-top: 20rpx;
  color: #667069;
  font-weight: 700;
}

.question-title {
  margin-top: 18rpx;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.55;
}

.cue-line {
  margin-top: 14rpx;
  color: #667069;
  font-size: 24rpx;
  font-weight: 700;
}
