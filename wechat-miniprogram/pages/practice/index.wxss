.question-text {
  margin-top: 28rpx;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.55;
}

.status-line {
  margin-top: 28rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #dfe4dc;
  color: #667069;
  font-weight: 700;
}

.button-row,
.button-grid {
  display: grid;
  gap: 16rpx;
  margin-top: 22rpx;
}

.button-row {
  grid-template-columns: repeat(3, 1fr);
}

.button-grid {
  grid-template-columns: repeat(2, 1fr);
}

.timer {
  font-size: 80rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.record-state {
  margin-top: 18rpx;
  color: #667069;
  font-weight: 700;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #667069;
}

.subtitle {
  color: #17201a;
  font-size: 30rpx;
  font-weight: 900;
}

.small {
  min-width: 120rpx;
  min-height: 58rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.empty,
.attempt-text {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #dfe4dc;
  border-radius: 12rpx;
  color: #667069;
  line-height: 1.6;
}

.attempt {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #dfe4dc;
}

audio {
  width: 100%;
  margin-top: 14rpx;
}

textarea {
  width: 100%;
  min-height: 260rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #dfe4dc;
  border-radius: 12rpx;
  background: #fbfcfa;
  line-height: 1.7;
}

.score-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.score-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.score-grid view {
  min-height: 112rpx;
  padding: 18rpx;
  border: 1rpx solid #dfe4dc;
  border-radius: 12rpx;
}

.score-grid text {
  display: block;
  color: #667069;
  font-size: 23rpx;
  font-weight: 700;
}

.score-grid strong {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
}
